# Perspective Agent configuration
# Copy to agent.toml (same dir as exe or project root) or pass --config agent.toml
#
# Desktop management (recommended):
#   npm run tauri dev          # development
#   npx tauri build            # release → target/release/perspective-agent-app.exe
#
# MCP server only (CLI / sidecar):
#   perspective-agent.exe --serve --config agent.toml

port = 9876
bind = "0.0.0.0"

# Optional Bearer token for /mcp (recommended when using tunnel/public exposure)
# token = "change-me-to-a-long-random-string"

# Audit log path (default: perspective-agent-audit.log next to exe)
# audit_log = "perspective-agent-audit.log"

# Public/tunnel MCP URL shown in desktop app (Perspective remote agent URL)
# public_mcp_url = "http://your-host:9876/mcp"

[limits]
# All byte limits are in bytes; desktop app edits them as MiB.
max_read_bytes = 10485760      # 10 MiB — read_file upper bound
max_write_bytes = 10485760     # 10 MiB — write_file upper bound
max_list_entries = 10000       # list_dir max returned entries
max_list_depth = 10            # list_dir max recursion depth
max_git_diff_bytes = 1048576   # 1 MiB — git_diff truncation

# Path sandbox: only paths under these roots are allowed.
# If empty, all paths are allowed (unsafe for tunnel).
[[roots]]
name = "perspective-agent"
path = "D:/Preoject/pulic/perspective-agent"

# [[roots]]
# name = "another-project"
# path = "D:/Projects/another"
