{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MCP Host Agent",
  "version": "0.1.1",
  "identifier": "dev.mcphost.agent",
  "build": {
    "beforeDevCommand": "npm run build:ui",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MCP Host Agent",
        "width": 1024,
        "height": 760,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
